# photo-edit-fusion environment variables
# Copy to .env and fill in any keys you have. All keys are OPTIONAL —
# the app degrades gracefully (returns 503 integration_disabled) when missing.

# --- Server runtime ---
PEF_SERVER_PORT=4317
PEF_SERVER_HOST=127.0.0.1
PEF_DATA_DIR=./data
PEF_CORS_ORIGIN=http://localhost:5173
PEF_RATE_LIMIT_MAX=120
PEF_RATE_LIMIT_WINDOW_MS=60000
PEF_MAX_UPLOAD_BYTES=26214400
PEF_LOG_LEVEL=info

# --- Font identification (optional, primary) ---
# WhatTheFont (MyFonts). https://www.myfonts.com/pages/whatthefont
WHATTHEFONT_API_KEY=
WHATTHEFONT_API_URL=https://www.myfonts.com/api/whatthefont/v1

# --- Font identification (optional, fallback) ---
# Fontspring Matcherator. https://www.fontspring.com/matcherator
FONTSPRING_API_KEY=
FONTSPRING_API_URL=https://www.fontspring.com/api/matcherator/v2

# --- Background removal (optional) ---
# Remove.bg. https://www.remove.bg/api
REMOVE_BG_API_KEY=
REMOVE_BG_API_URL=https://api.remove.bg/v1.0/removebg

# --- Web client ---
VITE_API_BASE_URL=http://localhost:4317
VITE_APP_NAME=Photo Edit Fusion
